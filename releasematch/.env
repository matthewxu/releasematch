# =============================================================================
# ReleaseMatch 环境变量配置模板
# =============================================================================
# 用法：
#   cp config.env.example .env
#   export $(grep -v '^#' .env | xargs)   # bash/zsh
#   或在 IDE / systemd 中逐条注入
#
# 本地 MySQL 测试流程见 docs/05-存储与部署配置.md
# =============================================================================

# 8090 ops 
RM_OPS_PASSWORD= 345621
RM_OPS_SESSION_HOURS=72
# RM_OPS_AUTH_DISABLED=1   # 仅排障关闭门禁


# ── 存储后端 ────────────────────────────────────────────────────────────────
# mysql = 本地/CI 使用 MySQL（默认，先测后上 D1）
# d1    = 生产 Cloudflare D1（T3 sync Worker）
RM_STORAGE_BACKEND=mysql

# ── Release 业务 MySQL（与 TMDB 元数据库分离）────────────────────────────────
RM_RELEASE_MYSQL_HOST=127.0.0.1
RM_RELEASE_MYSQL_PORT=3306
RM_RELEASE_MYSQL_DB=releasematch
RM_RELEASE_MYSQL_USER=root
RM_RELEASE_MYSQL_PASSWORD=123456

# ── TMDB 元数据桥接（可选，只读；与 Release 库可同实例不同 database）────────
RM_TMDB_DATA_MODE=standalone
RM_MYSQL_HOST=127.0.0.1
RM_MYSQL_PORT=3306
RM_MYSQL_DB=tmdbmeta
RM_MYSQL_USER=root
RM_MYSQL_PASSWORD=123456

# ── TMDB API（扩槽 imdb/tvdb；经 Cloudflare CORS Proxy）────────────────────
RM_TMDB_API_KEY=e7c05d8f0d4299f95d81d4ab94d27a9e
RM_TMDB_CORS_PROXY=https://api.weidaohang.org/cp/
RM_TMDB_API_BASE=https://api.themoviedb.org/3

# ── 站点 ────────────────────────────────────────────────────────────────────
RM_SITE_ORIGIN=https://releasematch.com
RM_SHOW_IG_DEBUG=0
# 1=禁止爬虫（软上线）；确认后改为 0，并恢复 robots.txt Allow+Sitemap
RM_BLOCK_CRAWLERS=1
# 是否启用 EN/中文 切换器
RM_SITE_I18N_ENABLED=true

# 站点 UI 语言：en | zh
RM_SITE_LOCALE=en

# ── Cloudflare D1（生产；本地测试可忽略）────────────────────────────────────
RM_D1_DATABASE_NAME=releasematch
RM_D1_BINDING=DB

# 数据源已迁至 workflow/torrent_sources/accounts.local.json（见 docs/15）

