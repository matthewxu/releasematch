# =============================================================================
# ReleaseMatch 环境变量配置模板
# =============================================================================
# 用法：
#   cp config.env.example .env
#   编辑 RM_RELEASE_MYSQL_* 等项
#   python -m workflow.run db init --seed   # 工作流会自动读取 .env
#
# 多地开发（私有仓）：真实 .env 可入库同步，见 docs/15-多地多环境开发切换.md
#   - 日常请把 RM_RELEASE_MYSQL_HOST 指向共享远程库（勿两地各用本机权威库）
#   - RM_CRAWLER_TMDB_ROOT 为 OS 路径，勿互相覆盖；到机后 export 本机路径
#   - 仓库须保持 private；转 public 前先轮换密钥
#
# 本地 MySQL 测试流程见 docs/05-存储与部署配置.md
# =============================================================================

# ── 存储后端 ────────────────────────────────────────────────────────────────
# mysql = 本地/CI 使用 MySQL（默认，先测后上 D1）
# d1    = 生产 Cloudflare D1（T3 sync Worker）
RM_STORAGE_BACKEND=mysql

# ── Release 业务 MySQL（与 TMDB 元数据库分离）────────────────────────────────
RM_RELEASE_MYSQL_HOST=127.0.0.1
RM_RELEASE_MYSQL_PORT=3306
RM_RELEASE_MYSQL_DB=releasematch
RM_RELEASE_MYSQL_USER=root
RM_RELEASE_MYSQL_PASSWORD=

# ── TMDB 元数据桥接（可选，只读；与 Release 库可同实例不同 database）────────
RM_TMDB_DATA_MODE=standalone
RM_MYSQL_HOST=127.0.0.1
RM_MYSQL_PORT=3306
RM_MYSQL_DB=test
RM_MYSQL_USER=
RM_MYSQL_PASSWORD=

# ── TMDB API（扩槽 external_ids；参考 tmdbpy crawler_tmdb）──────────────────
# RM_TMDB_API_KEY=your_tmdb_v3_api_key
# RM_TMDB_CORS_PROXY=https://api.weidaohang.org/cp/
# RM_TMDB_API_BASE=https://api.themoviedb.org/3
# Ops TV 季集：sibling crawler_tmdb 根目录；拉取结果写入业务 MySQL（tmdb_tv_* / tmdb_api_cache）
# RM_CRAWLER_TMDB_ROOT=C:/Users/you/Desktop/trafficforvideo/tmdb/tmdbpy/crawler_tmdb

# ── 站点 ────────────────────────────────────────────────────────────────────
RM_SITE_ORIGIN=https://releasematch.com

# ── Ops 控制台登录（python -m workflow.run ops serve）────────────────────────
# 非空则启用 /login.html 密码门禁（Cookie 会话）；改密后旧会话失效
# RM_OPS_PASSWORD=change-me
# RM_OPS_SESSION_HOURS=72
# RM_OPS_AUTH_DISABLED=0

# ── 生成器 Debug（本地测试；生产务必 0）──────────────────────────────────────
# 1/true/yes/on = 页面底部展示 IG 分级 debug 面板（自动 noindex）
RM_SHOW_IG_DEBUG=0

# ── 爬虫开关（软上线：先禁止，确认后再开放）──────────────────────────────────
# 1 = 页面全站 noindex,nofollow；须同时保持 portal/static/robots.txt 为 Disallow: /
# 0 = 开放收录；改 robots.txt 为 Allow + Sitemap 后重新 generate + deploy
RM_BLOCK_CRAWLERS=1

# ── Cloudflare D1（生产；本地测试可忽略）────────────────────────────────────
RM_D1_DATABASE_NAME=releasematch
RM_D1_BINDING=DB

# ── 数据源（Jackett / 代理 / 源站）──────────────────────────────────────────
# 请编辑 workflow/torrent_sources/accounts.local.json（模板 accounts.example.json）
# 勿再在本文件写 JACKETT_* / TORRENT_* / EZTV|YTS|NYAA|DMHY_BASE_URL，避免与 accounts 冲突
