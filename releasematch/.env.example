# ReleaseMatch local environment (copy to .env and fill in values)
# PowerShell: Copy-Item .env.example .env

# TMDB metadata bridge: standalone | mysql
RM_TMDB_DATA_MODE=standalone

# Optional: read-only TMDB MySQL (when RM_TMDB_DATA_MODE=mysql)
# RM_MYSQL_HOST=127.0.0.1
# RM_MYSQL_PORT=3306
# RM_MYSQL_DB=test
# RM_MYSQL_USER=
# RM_MYSQL_PASSWORD=

# Jackett (overrides accounts.local.json when set)
# JACKETT_BASE_URL=http://127.0.0.1:9117
# JACKETT_API_KEY=

# Torrent source base URLs (optional overrides)
# EZTV_BASE_URL=https://eztvx.to
# YTS_BASE_URL=https://yts.lt
# NYAA_BASE_URL=https://nyaa.si
# 生成器：页面 IG debug 面板（生产务必 false）
# RM_SHOW_IG_DEBUG=false

# 页面 UI 国际化：true 时顶栏显示 EN/中文 切换（localStorage rm_locale）
# RM_SITE_I18N_ENABLED=false

# 站点 UI 语言：en | zh（关闭 i18n 时为唯一语言；开启时为默认语言）
# RM_SITE_LOCALE=en
